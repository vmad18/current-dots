def truncate(text, limit):
    text = " ".join(text.split())
    if len(text) <= limit:
        return text

    return text[: limit - 1].rstrip() + "…"


def active_window():
    result = subprocess.run(
        ["hyprctl", "activewindow", "-j"],
        check=True,
        capture_output=True,
        text=True,
        timeout=0.5,
    )
    return json.loads(result.stdout)


def icon_for(window_class):
    lowered = window_class.lower()
    return ICONS.get(lowered, "󰣆")


def main():
    claim_instance()
    emit_active_window(force=True)
    watch_hyprland_events()


def claim_instance():
    try:
        with open(LOCK_PATH, "r", encoding="utf-8") as lock_file:
            old_pid = int(lock_file.read().strip())
    except (FileNotFoundError, ValueError, OSError):
        old_pid = None

    if old_pid and old_pid != os.getpid():
        try:
            with open(f"/proc/{old_pid}/cmdline", "rb") as cmdline_file:
                cmdline = cmdline_file.read()
            if b"active_window.py" in cmdline:
                os.kill(old_pid, signal.SIGTERM)
        except OSError:
            pass

    with open(LOCK_PATH, "w", encoding="utf-8") as lock_file:
        lock_file.write(f"{os.getpid()}\n")


def emit_active_window(force=False):
    global LAST_KEY

    try:
        window = active_window()
    except (subprocess.SubprocessError, json.JSONDecodeError, OSError):
        print(json.dumps({"text": "󰣆 Desktop", "tooltip": "No active window"}), flush=True)
        return

    window_class = window.get("class") or window.get("initialClass") or "Window"
    title = window.get("title") or window_class or "Desktop"
    icon = icon_for(window_class)
    text = icon
    workspace = window.get("workspace", {}).get("name", "?")
    key = (
        window.get("address"),
        window_class,
        workspace,
    )

    if not force and key == LAST_KEY:
        return

    LAST_KEY = key

    tooltip = "\n".join(
        [
            escape(title, quote=False),
            f"App: {escape(window_class, quote=False)}",
            f"Workspace: {escape(str(workspace), quote=False)}",
        ]
    )

    print(json.dumps({"text": text, "tooltip": tooltip}, ensure_ascii=False), flush=True)


def hyprland_event_socket():
    runtime_dir = os.environ.get("XDG_RUNTIME_DIR")
    instance = os.environ.get("HYPRLAND_INSTANCE_SIGNATURE")

    if not runtime_dir or not instance:
        return None

    return os.path.join(runtime_dir, "hypr", instance, ".socket2.sock")


def should_refresh(event):
    return event.startswith(
        (
            "activewindow>>",
            "activewindowv2>>",
            "workspace>>",
            "focusedmon>>",
            "openwindow>>",
            "closewindow>>",
        )
    )


def watch_hyprland_events():
    socket_path = hyprland_event_socket()

    if not socket_path:
        while True:
            time.sleep(1)
            emit_active_window()

    while True:
        try:
            with socket.socket(socket.AF_UNIX, socket.SOCK_STREAM) as client:
                client.connect(socket_path)
                stream = client.makefile("r", encoding="utf-8", errors="replace")

                for event in stream:
                    if should_refresh(event):
                        emit_active_window()
        except OSError:
            time.sleep(0.5)


if __name__ == "__main__":
    main()
