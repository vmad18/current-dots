@define-color backgroundlight rgba(150, 150, 150, 0.25);
@define-color backgrounddark rgba(150, 150, 150, 0.1);
@define-color workspacesbackground1 rgba(150, 150, 150, 0.1);
@define-color workspacesbackground2 rgba(150, 150, 150, 0.1);
@define-color bordercolor rgba(0, 0, 0, 0.5);
@define-color bordershadow rgba(255, 255, 255, 0.2);
@define-color textcolor1 #FFFFFF;
@define-color textcolor2 #FFFFFF;
@define-color textcolor3 #000000;
@define-color iconcolor #000000;



